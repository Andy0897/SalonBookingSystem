@model SalonBookingSystem.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h2 class="fw-bold mb-2">

                            Създаване на акаунт

                        </h2>

                        <p class="text-muted mb-0">

                            Регистрирайте се, за да използвате системата.

                        </p>

                    </div>

                    <form asp-action="Register" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="FirstName"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="FirstName"
                                       class="form-control form-control-lg" />

                                <span asp-validation-for="FirstName"
                                      class="text-danger"></span>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="LastName"
                                       class="form-label fw-semibold"></label>

                                <input asp-for="LastName"
                                       class="form-control form-control-lg" />

                                <span asp-validation-for="LastName"
                                      class="text-danger"></span>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Email"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Email"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Email"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="PhoneNumber"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="PhoneNumber"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Password"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Password"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Password"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="ConfirmPassword"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="ConfirmPassword"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="ConfirmPassword"
                                  class="text-danger"></span>

                        </div>

                        <button type="submit"
                                class="btn btn-dark btn-lg w-100">

                            Регистрация

                        </button>

                    </form>

                    <hr class="my-4" />

                    <p class="text-center text-muted mb-0">

                        Вече имате акаунт?

                        <a asp-action="Login"
                           class="text-decoration-none fw-semibold">

                            Вход

                        </a>

                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}