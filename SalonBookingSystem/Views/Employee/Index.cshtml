@model IEnumerable<SalonBookingSystem.Models.Employee>

@{
    ViewData["Title"] = "Служители";
}

<div class="container mt-4">

    <h2>Служители</h2>

    <table class="table table-bordered table-hover shadow">

        <thead class="table-dark">

            <tr>

                <th>Име</th>

                <th>Специалност</th>

                <th>Работно време</th>

                <th width="180">Действия</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var employee in Model)
            {
                <tr>

                    <td>

                        @employee.User.FirstName
                        @employee.User.LastName

                    </td>

                    <td>

                        @employee.Specialty

                    </td>

                    <td>

                        @employee.WorkStart -
                        @employee.WorkEnd

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@employee.Id"
                           class="btn btn-warning btn-sm">

                            Редакция

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@employee.Id"
                           class="btn btn-danger btn-sm">

                            Изтрий

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>