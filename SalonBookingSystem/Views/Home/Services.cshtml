@model List<SalonBookingSystem.Models.BeautyService>

@{
    ViewData["Title"] = "Услуги";
}

<div class="container py-5">


    <div class="text-center mb-5">


        <h1 class="fw-bold">

            Нашите услуги

        </h1>


        <p class="text-muted">

            Изберете процедура и запазете удобен час.

        </p>


    </div>



    <div class="row">


        @foreach (var service in Model)
        {


            <div class="col-lg-4 col-md-6 mb-4">


                <div class="card border-0 shadow-sm h-100">


                    <div class="card-body p-4">


                        <h4 class="fw-bold">

                            @service.Name

                        </h4>


                        <p class="text-muted">

                            Професионална процедура от нашите специалисти.

                        </p>


                    </div>



                    <div class="card-footer bg-white border-0 p-4">


                        <h5>

                            @service.Price лв.

                        </h5>


                        <p class="text-muted">

                            @service.DurationMinutes минути

                        </p>




                        @if (User.Identity!.IsAuthenticated)
                        {

                            <a asp-controller="Reservation"
                               asp-action="Create"
                               class="btn btn-dark w-100">

                                Запази час

                            </a>

                        }
                        else
                        {

                            <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-outline-dark w-100">

                                Влез за резервация

                            </a>

                        }



                    </div>



                </div>


            </div>


        }



    </div>


</div>