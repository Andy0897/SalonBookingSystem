@model IEnumerable<SalonBookingSystem.Models.BeautyService>

@{
    ViewData["Title"] = "Услуги";
}

<div class="container py-5">


    <div class="d-flex justify-content-between align-items-center mb-4">


        <div>

            <h2 class="fw-bold mb-1">

                Услуги

            </h2>

            <p class="text-muted mb-0">

                Управление на предлаганите услуги в салона.

            </p>

        </div>


        <a asp-action="Create"
           class="btn btn-dark">

            + Добави услуга

        </a>


    </div>



    <div class="card border-0 shadow-sm">


        <div class="card-body p-0">


            @if (!Model.Any())
            {

                <div class="p-5 text-center">


                    <h5 class="fw-bold">

                        Няма добавени услуги

                    </h5>


                    <p class="text-muted">

                        Все още няма създадени услуги в системата.

                    </p>


                    <a asp-action="Create"
                       class="btn btn-dark">

                        Добави първата услуга

                    </a>


                </div>

            }
            else
            {


                <div class="table-responsive">


                    <table class="table table-hover align-middle mb-0">


                        <thead class="table-light">


                            <tr>

                                <th class="ps-4">
                                    Име
                                </th>

                                <th>
                                    Продължителност
                                </th>

                                <th>
                                    Цена
                                </th>

                                <th class="text-end pe-4">
                                    Действия
                                </th>

                            </tr>


                        </thead>



                        <tbody>


                            @foreach (var item in Model)
                            {

                                <tr>


                                    <td class="ps-4 fw-semibold">

                                        @item.Name

                                    </td>


                                    <td>

                                        @item.DurationMinutes мин.

                                    </td>


                                    <td>

                                        @item.Price лв.

                                    </td>


                                    <td class="text-end pe-4">


                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-secondary btn-sm">

                                            Детайли

                                        </a>


                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-dark btn-sm">

                                            Редакция

                                        </a>


                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm">

                                            Изтрий

                                        </a>


                                    </td>


                                </tr>

                            }


                        </tbody>


                    </table>


                </div>


            }


        </div>


    </div>


</div>