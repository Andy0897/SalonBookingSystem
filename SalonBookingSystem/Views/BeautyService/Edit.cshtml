@model SalonBookingSystem.Models.BeautyService

@{
    ViewData["Title"] = "Редактиране на услуга";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h2 class="fw-bold">
                            Редактиране на услуга
                        </h2>

                        <p class="text-muted">
                            Променете информацията за услугата.
                        </p>

                    </div>


                    <form asp-action="Edit">

                        <input type="hidden" asp-for="Id" />


                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>


                        <div class="mb-3">

                            <label asp-for="Name"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Name"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>

                        </div>


                        <div class="mb-3">

                            <label asp-for="DurationMinutes"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="DurationMinutes"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="DurationMinutes"
                                  class="text-danger"></span>

                        </div>


                        <div class="mb-4">

                            <label asp-for="Price"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Price"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Price"
                                  class="text-danger"></span>

                        </div>


                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Назад

                            </a>

                            <button class="btn btn-dark px-4">

                                Запази

                            </button>

                        </div>


                    </form>


                </div>

            </div>

        </div>

    </div>

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}