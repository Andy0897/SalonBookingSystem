@model SalonBookingSystem.Models.BeautyService

<div class="container mt-5">

	<div class="alert alert-danger">

		<h3>Сигурни ли сте?</h3>

		<hr />

		<p>

			<b>@Model.Name</b>

		</p>

		<p>

			Цена:

			<b>@Model.Price лв.</b>

		</p>

		<p>

			Продължителност:
			<b>@Model.DurationMinutes минути</b>
		</p>

		<form asp-action="Delete">

			<input type="hidden" asp-for="Id" />

			<button class="btn btn-danger">

				Изтрий

			</button>

			<a asp-action="Index"
			   class="btn btn-secondary">

				Отказ

			</a>

		</form>

	</div>

</div>